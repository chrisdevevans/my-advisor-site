---
import BaseLayout from "@layouts/BaseLayout.astro";
import MarkdownIt from "markdown-it";
import page from "@data/pages/privacy.json";

const { meta, hero, intro, sections } = page;

const md = new MarkdownIt({ html: false, linkify: true, breaks: false });
const renderBody = (text: string) => md.render(text);
---

<BaseLayout title={meta.title} description={meta.description}>
  <section class="page-hero">
    <div class="container fade-up">
      <span class="eyebrow">{hero.eyebrow}</span>
      <h1>{hero.heading}</h1>
      <hr class="gold-rule" />
      <p class="legal-meta">{hero.lastUpdated}</p>
    </div>
  </section>

  <article class="section">
    <div class="container container--narrow legal">
      <p class="legal__intro fade-up">{intro}</p>

      {
        sections.map((sec) => (
          <section class="fade-up">
            <h2>{sec.heading}</h2>
            <div class="legal__body" set:html={renderBody(sec.body)} />
            {sec.contactBlock && (
              <p class="legal__contact">
                <strong>{sec.contactBlock.name}</strong><br />
                {sec.contactBlock.attn}<br />
                <Fragment set:html={sec.contactBlock.address.replace(/\n/g, "<br />")} /><br />
                <a href={sec.contactBlock.emailHref}>{sec.contactBlock.email}</a><br />
                <a href={sec.contactBlock.phoneHref}>{sec.contactBlock.phone}</a>
              </p>
            )}
          </section>
        ))
      }
    </div>
  </article>
</BaseLayout>

<style>
  .page-hero {
    padding-block: var(--space-9) var(--space-7);
    background:
      radial-gradient(ellipse 40% 60% at 90% 0%, rgba(201, 168, 76, 0.07), transparent 70%),
      var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .legal-meta {
    color: var(--color-muted);
    font-size: var(--fs-sm);
    letter-spacing: 0.04em;
    margin-top: var(--space-3);
  }

  .legal {
    font-size: var(--fs-md);
    line-height: 1.85;
    color: var(--color-text);
  }

  .legal__intro {
    color: var(--color-muted);
    font-size: var(--fs-md);
    margin-bottom: var(--space-7);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .legal section + section {
    margin-top: var(--space-7);
  }

  .legal h2 {
    font-size: var(--fs-2xl);
    font-family: var(--font-display);
    font-weight: 500;
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }

  .legal__body :global(p) {
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }

  .legal__body :global(strong) {
    color: var(--color-gold-light);
    font-weight: 600;
  }

  .legal__body :global(ul) {
    list-style: disc;
    padding-left: var(--space-5);
    margin-bottom: var(--space-4);
  }

  .legal__body :global(li) {
    margin-bottom: var(--space-3);
    line-height: 1.7;
  }

  .legal__body :global(a) {
    color: var(--color-gold);
    text-decoration: underline;
    text-decoration-color: rgba(201, 168, 76, 0.4);
    text-underline-offset: 3px;
    transition: color var(--t-base) var(--ease);
  }

  .legal__body :global(a:hover) {
    color: var(--color-gold-light);
  }

  .legal__contact {
    padding: var(--space-5);
    background-color: var(--color-surface);
    border-left: 2px solid var(--color-gold);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    line-height: 2;
    margin-top: var(--space-4);
  }

  .legal__contact a {
    color: var(--color-gold);
    text-decoration: underline;
    text-decoration-color: rgba(201, 168, 76, 0.4);
    text-underline-offset: 3px;
  }

  .legal__contact a:hover {
    color: var(--color-gold-light);
  }
</style>
