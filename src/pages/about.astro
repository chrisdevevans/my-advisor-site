---
import BaseLayout from "@layouts/BaseLayout.astro";
import TeamCard from "@components/TeamCard.astro";
import CTABanner from "@components/CTABanner.astro";
import page from "@data/pages/about.json";

const { meta, hero, story, values, timeline, teamPreview, cta } = page;
---

<BaseLayout title={meta.title} description={meta.description}>
  <section class="page-hero">
    <div class="container fade-up">
      <span class="eyebrow">{hero.eyebrow}</span>
      <h1>{hero.heading}</h1>
      <hr class="gold-rule" />
      <p class="lede">{hero.lede}</p>
    </div>
  </section>

  <section class="section" aria-labelledby="our-story">
    <div class="container container--narrow story">
      <header class="fade-up">
        <span class="eyebrow">{story.eyebrow}</span>
        <h2 id="our-story">{story.heading}</h2>
      </header>

      <div class="story__body fade-up">
        <p>{story.paragraph1}</p>
        <p>{story.paragraph2}</p>
        <p class="story__mission">
          <strong>{story.missionLabel}</strong> {story.missionText}
        </p>
      </div>
    </div>
  </section>

  <section class="section section--surface" aria-labelledby="values">
    <div class="container">
      <header class="section-head fade-up">
        <span class="eyebrow">{values.eyebrow}</span>
        <h2 id="values">{values.heading}</h2>
      </header>

      <div class="values-grid">
        {
          values.items.map((v) => (
            <div class="value card fade-up">
              <div class="value__icon" aria-hidden="true">
                {v.icon === "shield" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3l8 3v6c0 5-3.5 8.5-8 9-4.5-.5-8-4-8-9V6l8-3z" />
                    <path d="M9 12l2 2 4-4" />
                  </svg>
                )}
                {v.icon === "eye" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 12s4-7 10-7 10 7 10 7-4 7-10 7-10-7-10-7z" />
                    <circle cx="12" cy="12" r="3" />
                  </svg>
                )}
                {v.icon === "compass" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="9" />
                    <polygon points="16,8 13,13 8,16 11,11" />
                  </svg>
                )}
                {v.icon === "tree" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3v18" />
                    <path d="M12 9l-4-4M12 9l4-4M12 15l-5-3M12 15l5-3" />
                  </svg>
                )}
              </div>
              <h3>{v.title}</h3>
              <p>{v.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="timeline">
    <div class="container container--narrow">
      <header class="section-head fade-up">
        <span class="eyebrow">{timeline.eyebrow}</span>
        <h2 id="timeline">{timeline.heading}</h2>
      </header>

      <ol class="timeline">
        {
          timeline.items.map((item) => (
            <li class="timeline__item fade-up">
              <span class="timeline__year">{item.year}</span>
              <p class="timeline__text">{item.text}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section section--surface" aria-labelledby="team-preview">
    <div class="container">
      <header class="section-head fade-up">
        <span class="eyebrow">{teamPreview.eyebrow}</span>
        <h2 id="team-preview">{teamPreview.heading}</h2>
        <p class="lede">{teamPreview.lede}</p>
      </header>

      <div class="team-preview-grid">
        {
          teamPreview.members.map((m) => (
            <TeamCard
              name={m.name}
              title={m.title}
              bio={m.bio}
              credentials={m.credentials}
            />
          ))
        }
      </div>

      <div class="team-preview__cta fade-up">
        <a href={teamPreview.linkHref} class="btn btn--ghost">{teamPreview.linkLabel}</a>
      </div>
    </div>
  </section>

  <CTABanner
    heading={cta.heading}
    description={cta.description}
    ctaLabel={cta.ctaLabel}
    ctaHref={cta.ctaHref}
  />
</BaseLayout>

<style>
  .page-hero {
    padding-block: var(--space-9) var(--space-7);
    background:
      radial-gradient(ellipse 40% 60% at 90% 0%, rgba(201, 168, 76, 0.07), transparent 70%),
      var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .page-hero h1 {
    max-width: 16ch;
  }

  .page-hero .lede {
    margin-top: var(--space-4);
  }

  .section-head {
    max-width: 720px;
    margin-bottom: var(--space-7);
  }

  .section-head h2 {
    margin-bottom: var(--space-4);
  }

  .section--surface {
    background-color: var(--color-surface);
    border-block: 1px solid var(--color-border);
  }

  .story header {
    margin-bottom: var(--space-6);
  }

  .story__body p + p {
    margin-top: var(--space-4);
  }

  .story__body p {
    color: var(--color-text);
    line-height: 1.8;
    font-size: var(--fs-md);
  }

  .story__mission {
    padding: var(--space-5);
    border-left: 2px solid var(--color-gold);
    background-color: var(--color-surface);
    margin-top: var(--space-6) !important;
    font-style: italic;
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 640px) {
    .values-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .values-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .value {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    height: 100%;
  }

  .value__icon {
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gold);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-2);
  }

  .value__icon svg {
    width: 24px;
    height: 24px;
  }

  .value h3 {
    font-size: var(--fs-lg);
    font-family: var(--font-display);
    font-weight: 500;
  }

  .value p {
    color: var(--color-muted);
    line-height: 1.6;
  }

  .timeline {
    position: relative;
    padding-left: var(--space-6);
    border-left: 1px solid var(--color-border-strong);
  }

  .timeline__item {
    position: relative;
    padding-block: var(--space-5);
  }

  .timeline__item + .timeline__item {
    border-top: 1px solid var(--color-border);
  }

  .timeline__item::before {
    content: "";
    position: absolute;
    left: calc(var(--space-6) * -1 - 5px);
    top: calc(var(--space-5) + 0.6rem);
    width: 11px;
    height: 11px;
    background-color: var(--color-gold);
    border: 2px solid var(--color-bg);
    border-radius: 50%;
  }

  .timeline__year {
    display: inline-block;
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    color: var(--color-gold);
    font-weight: 500;
    margin-bottom: var(--space-2);
  }

  .timeline__text {
    color: var(--color-text);
    line-height: 1.7;
  }

  .team-preview-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 768px) {
    .team-preview-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .team-preview__cta {
    margin-top: var(--space-7);
    text-align: center;
  }
</style>
