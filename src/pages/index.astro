---
import BaseLayout from "@layouts/BaseLayout.astro";
import HeroSection from "@components/HeroSection.astro";
import ServiceCard from "@components/ServiceCard.astro";
import TestimonialCard from "@components/TestimonialCard.astro";
import CTABanner from "@components/CTABanner.astro";
import page from "@data/pages/home.json";

const { meta, hero, servicesPreview, aboutTeaser, testimonials, cta } = page;
---

<BaseLayout title={meta.title} description={meta.description}>
  <HeroSection
    headline={hero.headline}
    subheadline={hero.subheadline}
    ctas={[
      { ...hero.primaryCTA, variant: "primary" },
      { ...hero.secondaryCTA, variant: "ghost" },
    ]}
    trustItems={hero.trustItems}
  />

  <section class="section" aria-labelledby="services-preview">
    <div class="container">
      <header class="section-head fade-up">
        <span class="eyebrow">{servicesPreview.eyebrow}</span>
        <h2 id="services-preview">{servicesPreview.heading}</h2>
        <p class="lede">{servicesPreview.lede}</p>
      </header>

      <div class="services-grid">
        {
          servicesPreview.items.map((s) => (
            <ServiceCard
              icon={s.icon}
              title={s.title}
              description={s.description}
              href={s.href}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="about-teaser section" aria-labelledby="about-teaser">
    <div class="container about-teaser__grid">
      <div class="about-teaser__copy fade-up">
        <span class="eyebrow">{aboutTeaser.eyebrow}</span>
        <h2 id="about-teaser">{aboutTeaser.heading}</h2>
        <hr class="gold-rule" />
        <p class="lede">{aboutTeaser.leadParagraph}</p>
        <p class="text-muted">{aboutTeaser.supportingParagraph}</p>
        <a href={aboutTeaser.linkHref} class="btn--link">{aboutTeaser.linkLabel}</a>
      </div>

      <ul class="stats fade-up">
        {
          aboutTeaser.stats.map((s) => (
            <li class="stats__item">
              <span class="stats__value">{s.value}</span>
              <span class="stats__label">{s.label}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section section--testimonials" aria-labelledby="testimonials">
    <div class="container">
      <header class="section-head text-center fade-up">
        <span class="eyebrow">{testimonials.eyebrow}</span>
        <h2 id="testimonials">{testimonials.heading}</h2>
        <hr class="gold-rule gold-rule--center" />
      </header>

      <div class="testimonials-grid">
        {
          testimonials.items.map((t) => (
            <TestimonialCard quote={t.quote} name={t.name} role={t.role} />
          ))
        }
      </div>
    </div>
  </section>

  <CTABanner
    heading={cta.heading}
    description={cta.description}
    ctaLabel={cta.ctaLabel}
    ctaHref={cta.ctaHref}
  />
</BaseLayout>

<style>
  .section-head {
    max-width: 720px;
    margin-bottom: var(--space-7);
  }

  .section-head.text-center {
    margin-inline: auto;
  }

  .section-head h2 {
    margin-bottom: var(--space-4);
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 720px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .about-teaser {
    background-color: var(--color-surface);
    border-block: 1px solid var(--color-border);
  }

  .about-teaser__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
  }

  @media (min-width: 960px) {
    .about-teaser__grid {
      grid-template-columns: 1.2fr 1fr;
      gap: var(--space-9);
    }
  }

  .stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background-color: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-6);
    background-color: var(--color-bg);
    text-align: center;
  }

  .stats__value {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-gold);
    font-weight: 500;
    line-height: 1.1;
  }

  .stats__label {
    font-size: var(--fs-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 768px) {
    .testimonials-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
