---
import BaseLayout from "@layouts/BaseLayout.astro";
import ServiceCard from "@components/ServiceCard.astro";
import CTABanner from "@components/CTABanner.astro";
import page from "@data/pages/services.json";

const { meta, hero, services, process, fees, cta } = page;
---

<BaseLayout title={meta.title} description={meta.description}>
  <section class="page-hero">
    <div class="container fade-up">
      <span class="eyebrow">{hero.eyebrow}</span>
      <h1>{hero.heading}</h1>
      <hr class="gold-rule" />
      <p class="lede">{hero.lede}</p>
    </div>
  </section>

  <section class="section" aria-labelledby="services">
    <div class="container">
      <h2 id="services" class="sr-only">Our Services</h2>
      <div class="services-grid">
        {
          services.map((s) => (
            <ServiceCard
              id={s.id}
              icon={s.icon}
              title={s.title}
              description={s.description}
              audience={s.audience}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--surface" aria-labelledby="process">
    <div class="container">
      <header class="section-head fade-up">
        <span class="eyebrow">{process.eyebrow}</span>
        <h2 id="process">{process.heading}</h2>
        <p class="lede">{process.lede}</p>
      </header>

      <ol class="process">
        {
          process.steps.map((step) => (
            <li class="process__step fade-up">
              <span class="process__num">{step.n}</span>
              <h3 class="process__title">{step.title}</h3>
              <p class="process__body">{step.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section" aria-labelledby="fees">
    <div class="container container--narrow">
      <header class="section-head fade-up">
        <span class="eyebrow">{fees.eyebrow}</span>
        <h2 id="fees">{fees.heading}</h2>
        <p class="lede">{fees.lede}</p>
      </header>

      <div class="fee-table fade-up">
        <div class="fee-table__head">
          <span>{fees.tableHeader}</span>
          <span>{fees.tableRateHeader}</span>
        </div>
        {
          fees.tiers.map((tier) => (
            <div class="fee-table__row">
              <span>{tier.range}</span>
              <span class="fee-table__rate">{tier.rate}</span>
            </div>
          ))
        }
      </div>

      <p class="fee-note fade-up">{fees.note}</p>
    </div>
  </section>

  <CTABanner
    heading={cta.heading}
    description={cta.description}
    ctaLabel={cta.ctaLabel}
    ctaHref={cta.ctaHref}
  />
</BaseLayout>

<style>
  .page-hero {
    padding-block: var(--space-9) var(--space-7);
    background:
      radial-gradient(ellipse 40% 60% at 90% 0%, rgba(201, 168, 76, 0.07), transparent 70%),
      var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .page-hero .lede {
    margin-top: var(--space-4);
  }

  .section-head {
    max-width: 720px;
    margin-bottom: var(--space-7);
  }

  .section-head h2 {
    margin-bottom: var(--space-4);
  }

  .section--surface {
    background-color: var(--color-surface);
    border-block: 1px solid var(--color-border);
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }
  }

  .process {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    counter-reset: step;
  }

  @media (min-width: 720px) {
    .process {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .process {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-4);
    }
  }

  .process__step {
    position: relative;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6) var(--space-5);
    transition: border-color var(--t-base) var(--ease);
  }

  .process__step:hover {
    border-color: var(--color-border-strong);
  }

  .process__num {
    display: inline-block;
    font-family: var(--font-display);
    font-size: var(--fs-3xl);
    color: var(--color-gold);
    margin-bottom: var(--space-3);
    font-weight: 500;
    line-height: 1;
  }

  .process__title {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    margin-bottom: var(--space-3);
    font-weight: 500;
  }

  .process__body {
    color: var(--color-muted);
    line-height: 1.65;
    font-size: var(--fs-sm);
  }

  .fee-table {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-block: var(--space-6);
  }

  .fee-table__head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background-color: var(--color-surface-2);
    border-bottom: 1px solid var(--color-border);
    font-size: var(--fs-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-weight: 500;
  }

  .fee-table__row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-4);
    padding: var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }

  .fee-table__row:last-child {
    border-bottom: 0;
  }

  .fee-table__rate {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    color: var(--color-gold);
    font-weight: 500;
  }

  .fee-note {
    color: var(--color-muted);
    font-size: var(--fs-sm);
    line-height: 1.7;
    border-left: 2px solid var(--color-gold);
    padding-left: var(--space-4);
  }
</style>
