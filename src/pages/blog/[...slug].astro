---
import { slugifyLabel } from "@components/utils/slugify";
import Heading from "@core-elements/heading/Heading.astro";
import Image from "@core-elements/image/Image.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import Page from "@layouts/Page.astro";
import CustomSection from "@page-sections/builders/custom-section/CustomSection.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

// Automatically import all components from building-blocks and page-sections for MDX
const buildingBlocksImports = import.meta.glob("../../components/building-blocks/**/*.astro", {
  eager: true,
});

const pageSectionsImports = import.meta.glob("../../components/page-sections/**/*.astro", {
  eager: true,
});

// Merge both import objects
const componentImports = { ...buildingBlocksImports, ...pageSectionsImports };

// Build components object with PascalCase names from file paths
const mdxComponents: Record<string, any> = {};

Object.entries(componentImports).forEach(([path, module]) => {
  const pathParts = path.split("/");
  const fileName = pathParts[pathParts.length - 1].replace(".astro", "");

  // Component name is already PascalCase from filename
  const componentName = fileName;

  mdxComponents[componentName] = (module as any).default;
});

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post: CollectionEntry<"blog">) => {
    const slug = post.id.replace(/\.mdx?$/, "");

    return {
      params: { slug },
      props: { post },
    };
  });
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);
const date = post.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const dateIso = post.data.date.toISOString().slice(0, 10);
const article = {
  publishedTime: post.data.date.toISOString(),
  author: post.data.author,
  tags: post.data.tags,
};
---

<Page
  title={post.data.title}
  description={post.data.description}
  keywords={post.data.keywords}
  image={post.data.image}
  type="article"
  article={article}
>
  <CustomSection
    maxContentWidth="xl"
    paddingHorizontal="lg"
    paddingVertical="4xl"
    colorScheme="inherit"
    backgroundColor="base"
    class="post-container"
    data-pagefind-filter="Type:Article"
  >
    <SimpleText
      size="sm"
      class="post-meta"
      data-prop="author"
    >
      <time
        datetime={dateIso}
        data-pagefind-meta={`published:${dateIso}`}
        data-pagefind-sort={`date:${dateIso}`}
      >
        {date}
      </time>

      •
      <span
        data-pagefind-filter="Author"
        data-pagefind-meta="author"
      >
        {post.data.author}
      </span>
    </SimpleText>

    <Heading
      data-prop="title"
      data-pagefind-meta="title"
      level="h1"
      size="2xl"
      class="post-title"
    >
      {post.data.title}
    </Heading>

    {
      post.data.description && (
        <SimpleText
          data-prop="description"
          data-pagefind-meta="description"
          data-pagefind-weight="3"
          size="lg"
          class="post-description"
        >
          {post.data.description}
        </SimpleText>
      )
    }

    {
      post.data.tags.length > 0 && (
        <p
          class="post-tags"
          data-editable="array"
          data-prop="tags"
          data-direction="row"
        >
          {post.data.tags.map((tag, i) => (
            <>
              {i > 0 && " • "}
              <a
                class="post-tag-link"
                href={`/blog/tag/${slugifyLabel(tag.trim())}/`}
                data-pagefind-filter="Tag"
                data-editable="array-item"
                data-id={tag.trim()}
              >
                {tag.trim()}
              </a>
            </>
          ))}
        </p>
      )
    }

    {
      post.data.image && (
        <Image
          source={post.data.image}
          alt={post.data.title}
          rounded={true}
          data-prop-src="image"
          data-prop-alt="title"
          class="post-image"
          aspectRatio="horizontal-strip"
          positionVertical="center"
          imageElementAttributes={{
            "data-pagefind-meta": "image[src], image_alt[alt]",
          }}
        />
      )
    }

    <div
      class="post"
      data-editable="text"
      data-prop="@content"
    >
      <Content components={mdxComponents} />
    </div>
  </CustomSection>
</Page>

<style is:global>
  .post-container.custom-section > .outer-content > .content {
    padding-bottom: 0 !important;
  }

  .post-meta {
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-sm);
  }

  .post-title {
    margin-bottom: var(--spacing-xs);
  }

  .post-description {
    color: var(--color-text-muted);
    margin-bottom: 0;
    margin-top: var(--spacing-xs);
  }

  .post-tags {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    margin-bottom: 0;
    margin-top: var(--spacing-sm);
  }

  .post {
    display: grid;
    grid-template-columns:
      minmax(0, 1fr)
      minmax(0, 70ch)
      minmax(0, 1fr);
    margin-inline: auto;
    margin-top: var(--spacing-xl);
  }

  .post > * {
    grid-column: 2;
  }

  .post > .wide,
  .post > pre,
  .post > .image,
  .post > .video {
    grid-column: 1 / -1;
  }

  .post > h1,
  .post > h2,
  .post > h3,
  .post > h4,
  .post > h5,
  .post > h6 {
    margin-bottom: 0;
    margin-top: 1rem;

    &:first-child {
      margin-top: 0;
    }
  }

  .post > .astro-code {
    margin-block: var(--spacing-xl);
  }

  .post-image {
    margin-top: var(--spacing-xl);
  }

  .post-tags .post-tag-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.15em;
  }

  .post-tags .post-tag-link:hover {
    color: var(--color-text-strong);
    text-decoration-thickness: 2px;
  }
</style>
