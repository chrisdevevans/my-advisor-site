---
import BlogPostListingGrid from "@component-utils/BlogPostListingGrid.astro";
import Page from "@layouts/Page.astro";
import CustomSection from "@page-sections/builders/custom-section/CustomSection.astro";
import { getBlogPostsSortedByDate, loadBlogPageContext } from "../../utils/blog";

type Paginate = (_data: any[], _opts: { pageSize: number }) => any;

export interface Props {
  page: { data: any[]; currentPage: number };
}

export async function getStaticPaths({ paginate }: { paginate: Paginate }) {
  const blogPosts = await getBlogPostsSortedByDate();

  return paginate(blogPosts, { pageSize: 12 });
}

const { page } = Astro.props as Props;

const { blogPage, heroSections } = await loadBlogPageContext();

const basePageTitle = blogPage?.data?.title ?? "Blog";
const pageTitle =
  page.currentPage > 1 ? `${basePageTitle} – Page ${page.currentPage}` : basePageTitle;
const baseDescription =
  blogPage?.data?.description ??
  "Read our latest articles and insights on web development, design, and technology.";
const pageDescription =
  page.currentPage > 1
    ? `${baseDescription} Page ${page.currentPage} of the blog archive.`
    : baseDescription;
---

<Page
  frontmatter={{
    title: pageTitle,
    description: pageDescription,
    pageSections: heroSections,
  }}
  disablePagefind={page.currentPage > 1}
>
  <CustomSection
    maxContentWidth="2xl"
    paddingHorizontal="lg"
    paddingVertical="none"
    colorScheme="inherit"
    backgroundColor="base"
  >
    <BlogPostListingGrid
      page={page}
      emptyMessage="No blog posts yet. Check back soon!"
    />
  </CustomSection>
</Page>
