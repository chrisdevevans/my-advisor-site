---
import BaseLayout from "@layouts/BaseLayout.astro";
import CTABanner from "@components/CTABanner.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const isoDate = post.data.date.toISOString().split("T")[0];

// Estimated read time based on rendered body length
const rawText = post.body ?? "";
const wordCount = rawText.split(/\s+/).filter(Boolean).length;
const readMinutes = Math.max(1, Math.round(wordCount / 220));
---

<BaseLayout
  title={post.data.title}
  description={post.data.excerpt}
>
  <article class="post">
    <header class="post__header">
      <div class="container container--narrow fade-up">
        {
          post.data.tags.length > 0 && (
            <ul class="post__tags" aria-label="Tags">
              {post.data.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
          )
        }
        <h1 class="post__title">{post.data.title}</h1>
        <p class="post__excerpt">{post.data.excerpt}</p>

        <div class="post__byline">
          <span class="post__author">By {post.data.author}</span>
          <span class="post__dot" aria-hidden="true">·</span>
          <time datetime={isoDate}>{formattedDate}</time>
          <span class="post__dot" aria-hidden="true">·</span>
          <span>{readMinutes} min read</span>
        </div>

        <hr class="gold-rule" />
      </div>
    </header>

    <div class="container container--narrow post__body fade-up">
      <Content />
    </div>

    <div class="container container--narrow post__footer fade-up">
      <hr class="gold-rule" />
      <a href="/blog/" class="btn--link post__back">Back to all articles</a>
    </div>
  </article>

  <CTABanner
    heading={`Have a question about ${post.data.tags[0] ?? "your finances"}?`}
    description="Our initial conversations are always free. No pressure, no pitch — just a useful exchange."
    ctaLabel="Schedule a Call"
    ctaHref="/contact/"
  />
</BaseLayout>

<style>
  .post {
    padding-top: var(--space-9);
  }

  .post__header {
    padding-bottom: var(--space-7);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-8);
  }

  .post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }

  .post__tags li {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.625rem;
    background: rgba(201, 168, 76, 0.08);
    border: 1px solid rgba(201, 168, 76, 0.25);
    color: var(--color-gold-light);
    border-radius: var(--radius-pill);
  }

  .post__title {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.15;
    margin-bottom: var(--space-4);
  }

  .post__excerpt {
    font-size: var(--fs-md);
    color: var(--color-muted);
    line-height: 1.65;
    margin-bottom: var(--space-5);
    max-width: 60ch;
  }

  .post__byline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--fs-sm);
    color: var(--color-muted);
  }

  .post__author {
    color: var(--color-text);
    font-weight: 500;
  }

  .post__dot {
    color: var(--color-gold);
  }

  /* Article body typography */
  .post__body {
    font-size: var(--fs-md);
    line-height: 1.85;
    color: var(--color-text);
  }

  .post__body :global(h2) {
    font-size: var(--fs-2xl);
    margin-top: var(--space-7);
    margin-bottom: var(--space-4);
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.2;
  }

  .post__body :global(h3) {
    font-size: var(--fs-xl);
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
    font-family: var(--font-display);
    font-weight: 500;
  }

  .post__body :global(p) {
    margin-bottom: var(--space-5);
  }

  .post__body :global(strong) {
    color: var(--color-gold-light);
    font-weight: 600;
  }

  .post__body :global(em) {
    color: var(--color-text);
  }

  .post__body :global(a) {
    color: var(--color-gold);
    text-decoration: underline;
    text-decoration-color: rgba(201, 168, 76, 0.4);
    text-underline-offset: 3px;
    transition: color var(--t-base) var(--ease);
  }

  .post__body :global(a:hover) {
    color: var(--color-gold-light);
  }

  .post__body :global(blockquote) {
    border-left: 3px solid var(--color-gold);
    padding: var(--space-2) var(--space-5);
    color: var(--color-muted);
    font-style: italic;
    margin-block: var(--space-5);
  }

  .post__body :global(ul),
  .post__body :global(ol) {
    margin-bottom: var(--space-5);
    padding-left: var(--space-5);
  }

  .post__body :global(ul) {
    list-style: disc;
  }

  .post__body :global(ol) {
    list-style: decimal;
  }

  .post__body :global(li) {
    margin-bottom: var(--space-3);
  }

  .post__body :global(code) {
    background-color: var(--color-surface);
    color: var(--color-gold-light);
    padding: 0.125rem 0.375rem;
    border-radius: 3px;
    font-size: 0.92em;
  }

  .post__body :global(hr) {
    border: 0;
    height: 1px;
    background-color: var(--color-border);
    margin-block: var(--space-7);
  }

  .post__footer {
    padding-block: var(--space-7) var(--space-8);
  }

  .post__back {
    margin-top: var(--space-5);
  }
</style>
