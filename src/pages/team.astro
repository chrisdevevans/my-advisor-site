---
import BaseLayout from "@layouts/BaseLayout.astro";
import TeamCard from "@components/TeamCard.astro";
import CTABanner from "@components/CTABanner.astro";

const team = [
  {
    name: "Robert Hargrove, CFP®, CFA",
    title: "Founding Partner",
    bio:
      "25 years of experience. Specializes in estate and retirement planning for executives and multi-generational families. Wharton MBA. Outside the office, you'll find him fly fishing in Montana or coaching his daughter's youth soccer team.",
    credentials: ["CFP®", "CFA", "Wharton MBA"],
    linkedin: "https://www.linkedin.com/",
  },
  {
    name: "Sarah Whitfield, CFP®",
    title: "Partner, Wealth Management",
    bio:
      "18 years of experience. Focuses on women navigating life transitions — divorce, widowhood, inheritance, business sale. CFA Institute member. An avid marathon runner with seven majors completed and one to go.",
    credentials: ["CFP®", "CFA Member"],
    linkedin: "https://www.linkedin.com/",
  },
  {
    name: "David Kim, CPA, CFP®",
    title: "Director of Tax Strategy",
    bio:
      "12 years of experience. Former Big 4 tax consultant. Specializes in business owners, real estate investors, and clients with complex multi-state tax pictures. Georgetown Law background. Quiet, methodical, and unusually fast with a spreadsheet.",
    credentials: ["CFP®", "CPA", "JD"],
    linkedin: "https://www.linkedin.com/",
  },
  {
    name: "Aisha Osei, CFP®",
    title: "Associate Advisor",
    bio:
      "6 years of experience. Our NextGen planning specialist — works with clients aged 30 to 50 on wealth accumulation, equity comp, and early-career planning. First-generation wealth builder herself, which makes her a particularly empathetic guide for clients in the same position.",
    credentials: ["CFP®"],
    linkedin: "https://www.linkedin.com/",
  },
];
---

<BaseLayout
  title="Our Team"
  description="Meet the advisors at Hargrove Wealth Advisory — CFP®, CFA, and CPA professionals who carry small books so they can do deep work for each client."
>
  <section class="page-hero">
    <div class="container fade-up">
      <span class="eyebrow">Our Team</span>
      <h1>Meet Our Team.</h1>
      <hr class="gold-rule" />
      <p class="lede">
        Four advisors. Decades of combined experience. One philosophy: small books, deep work,
        and a real relationship with every client.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="team-grid">
    <div class="container">
      <h2 id="team-grid" class="sr-only">Team Members</h2>
      <div class="team-grid">
        {
          team.map((m) => (
            <TeamCard
              name={m.name}
              title={m.title}
              bio={m.bio}
              credentials={m.credentials}
              linkedin={m.linkedin}
            />
          ))
        }
      </div>
    </div>
  </section>

  <CTABanner
    heading="Want to know who you'd be working with?"
    description="Every initial conversation is with a partner — not an intake coordinator."
  />
</BaseLayout>

<style>
  .page-hero {
    padding-block: var(--space-9) var(--space-7);
    background:
      radial-gradient(ellipse 40% 60% at 90% 0%, rgba(201, 168, 76, 0.07), transparent 70%),
      var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .page-hero .lede {
    margin-top: var(--space-4);
  }

  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 640px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }
  }
</style>
