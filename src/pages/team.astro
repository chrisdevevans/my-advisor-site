---
import BaseLayout from "@layouts/BaseLayout.astro";
import TeamCard from "@components/TeamCard.astro";
import CTABanner from "@components/CTABanner.astro";
import page from "@data/pages/team.json";

const { meta, hero, members, cta } = page;
---

<BaseLayout title={meta.title} description={meta.description}>
  <section class="page-hero">
    <div class="container fade-up">
      <span class="eyebrow">{hero.eyebrow}</span>
      <h1>{hero.heading}</h1>
      <hr class="gold-rule" />
      <p class="lede">{hero.lede}</p>
    </div>
  </section>

  <section class="section" aria-labelledby="team-grid">
    <div class="container">
      <h2 id="team-grid" class="sr-only">Team Members</h2>
      <div class="team-grid">
        {
          members.map((m) => (
            <TeamCard
              name={m.name}
              title={m.title}
              bio={m.bio}
              credentials={m.credentials}
              linkedin={m.linkedin}
            />
          ))
        }
      </div>
    </div>
  </section>

  <CTABanner
    heading={cta.heading}
    description={cta.description}
    ctaLabel={cta.ctaLabel}
    ctaHref={cta.ctaHref}
  />
</BaseLayout>

<style>
  .page-hero {
    padding-block: var(--space-9) var(--space-7);
    background:
      radial-gradient(ellipse 40% 60% at 90% 0%, rgba(201, 168, 76, 0.07), transparent 70%),
      var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .page-hero .lede {
    margin-top: var(--space-4);
  }

  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 640px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }
  }
</style>
