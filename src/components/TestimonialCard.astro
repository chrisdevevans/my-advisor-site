---
export interface Props {
  quote: string;
  name: string;
  role: string;
}

const { quote, name, role } = Astro.props;
---

<figure class="testimonial fade-up">
  <svg class="testimonial__mark" viewBox="0 0 32 32" aria-hidden="true">
    <path
      d="M9 22c0-4.5 3-7.5 6-9l1 2c-2 1-4 3-4 5h3v8H7v-6h2zm14 0c0-4.5 3-7.5 6-9l1 2c-2 1-4 3-4 5h3v8h-8v-6h2z"
      fill="currentColor"
    />
  </svg>
  <blockquote class="testimonial__quote">{quote}</blockquote>
  <figcaption class="testimonial__attr">
    <span class="testimonial__name">{name}</span>
    <span class="testimonial__role">{role}</span>
  </figcaption>
</figure>

<style>
  .testimonial {
    position: relative;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-gold);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    height: 100%;
    transition:
      border-color var(--t-base) var(--ease),
      transform var(--t-base) var(--ease);
  }

  .testimonial:hover {
    transform: translateY(-2px);
    border-color: var(--color-border-strong);
    border-left-color: var(--color-gold-light);
  }

  .testimonial__mark {
    width: 28px;
    height: 28px;
    color: var(--color-gold);
    opacity: 0.6;
  }

  .testimonial__quote {
    font-family: var(--font-display);
    font-size: var(--fs-md);
    line-height: 1.55;
    color: var(--color-text);
    font-style: italic;
    flex: 1;
  }

  .testimonial__attr {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  .testimonial__name {
    font-weight: 500;
    color: var(--color-text);
  }

  .testimonial__role {
    font-size: var(--fs-sm);
    color: var(--color-muted);
  }
</style>
