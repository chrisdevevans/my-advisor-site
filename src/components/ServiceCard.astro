---
export interface Props {
  icon?: "chart" | "compass" | "shield" | "scales" | "tree" | "briefcase";
  title: string;
  description: string;
  audience?: string;
  href?: string;
  linkLabel?: string;
  id?: string;
}

const {
  icon = "chart",
  title,
  description,
  audience,
  href,
  linkLabel = "Learn More",
  id,
} = Astro.props;
---

<article class="service card fade-up" id={id}>
  <div class="service__icon" aria-hidden="true">
    {
      icon === "chart" && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 3v18h18" />
          <path d="M7 14l4-4 4 3 5-7" />
        </svg>
      )
    }
    {
      icon === "compass" && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="9" />
          <polygon points="16,8 13,13 8,16 11,11" fill="currentColor" stroke="none" opacity="0.3" />
          <polygon points="16,8 13,13 8,16 11,11" />
        </svg>
      )
    }
    {
      icon === "shield" && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3l8 3v6c0 5-3.5 8.5-8 9-4.5-.5-8-4-8-9V6l8-3z" />
          <path d="M9 12l2 2 4-4" />
        </svg>
      )
    }
    {
      icon === "scales" && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3v18" />
          <path d="M5 7h14" />
          <path d="M5 7l-2 6a3 3 0 006 0L7 7" />
          <path d="M19 7l-2 6a3 3 0 006 0l-2-6" />
          <path d="M8 21h8" />
        </svg>
      )
    }
    {
      icon === "tree" && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3v18" />
          <path d="M12 9l-4-4" />
          <path d="M12 9l4-4" />
          <path d="M12 15l-5-3" />
          <path d="M12 15l5-3" />
        </svg>
      )
    }
    {
      icon === "briefcase" && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="7" width="18" height="13" rx="2" />
          <path d="M9 7V5a2 2 0 012-2h2a2 2 0 012 2v2" />
          <path d="M3 13h18" />
        </svg>
      )
    }
  </div>

  <h3 class="service__title">{title}</h3>
  <p class="service__desc">{description}</p>

  {
    audience && (
      <p class="service__audience">
        <span class="service__audience-label">Who this is for:</span> {audience}
      </p>
    )
  }

  {
    href && (
      <a href={href} class="btn--link service__link">
        {linkLabel}
      </a>
    )
  }
</article>

<style>
  .service {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    height: 100%;
  }

  .service__icon {
    width: 48px;
    height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gold);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    background: linear-gradient(135deg, rgba(201, 168, 76, 0.06), transparent);
    margin-bottom: var(--space-2);
  }

  .service__icon svg {
    width: 26px;
    height: 26px;
  }

  .service__title {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 500;
    color: var(--color-text);
  }

  .service__desc {
    color: var(--color-muted);
    line-height: 1.7;
    flex: 1;
  }

  .service__audience {
    font-size: var(--fs-sm);
    color: var(--color-text);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .service__audience-label {
    color: var(--color-gold);
    font-weight: 500;
  }

  .service__link {
    margin-top: var(--space-2);
    align-self: flex-start;
  }
</style>
