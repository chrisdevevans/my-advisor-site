---
export interface Props {
  title: string;
  href: string;
  date: Date | string;
  author: string;
  excerpt: string;
  tags?: string[];
  image?: string;
  imageAlt?: string;
}

const { title, href, date, author, excerpt, tags = [], image, imageAlt } = Astro.props;

const dateObj = date instanceof Date ? date : new Date(date);
const formattedDate = dateObj.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const isoDate = dateObj.toISOString().split("T")[0];
---

<article class="blog-card card fade-up">
  <a href={href} class="blog-card__cover" aria-hidden="true" tabindex="-1">
    {
      image ? (
        <img src={image} alt={imageAlt ?? ""} loading="lazy" decoding="async" />
      ) : (
        <span class="blog-card__cover-fallback">
          <svg viewBox="0 0 80 80" aria-hidden="true">
            <path
              d="M40 12 L60 30 L60 68 L20 68 L20 30 Z"
              fill="none"
              stroke="currentColor"
              stroke-width="1"
              opacity="0.6"
            />
            <line x1="20" y1="30" x2="60" y2="30" stroke="currentColor" stroke-width="1" opacity="0.6" />
            <line x1="40" y1="12" x2="40" y2="30" stroke="currentColor" stroke-width="1" opacity="0.6" />
          </svg>
        </span>
      )
    }
  </a>

  <div class="blog-card__body">
    {
      tags.length > 0 && (
        <ul class="blog-card__tags" aria-label="Tags">
          {tags.map((tag) => (
            <li>{tag}</li>
          ))}
        </ul>
      )
    }

    <h3 class="blog-card__title">
      <a href={href}>{title}</a>
    </h3>

    <p class="blog-card__excerpt">{excerpt}</p>

    <div class="blog-card__meta">
      <span class="blog-card__author">{author}</span>
      <span class="blog-card__dot" aria-hidden="true">·</span>
      <time datetime={isoDate}>{formattedDate}</time>
    </div>

    <a href={href} class="btn--link blog-card__link">Read More</a>
  </div>
</article>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    padding: 0;
    overflow: hidden;
    height: 100%;
  }

  .blog-card__cover {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: var(--color-surface-2);
    overflow: hidden;
  }

  .blog-card__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--t-slow) var(--ease);
  }

  .blog-card:hover .blog-card__cover img {
    transform: scale(1.03);
  }

  .blog-card__cover-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gold);
    background:
      radial-gradient(circle at 30% 30%, rgba(201, 168, 76, 0.08), transparent 60%),
      var(--color-surface-2);
  }

  .blog-card__cover-fallback svg {
    width: 56px;
    height: 56px;
  }

  .blog-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    flex: 1;
  }

  .blog-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .blog-card__tags li {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.625rem;
    background: rgba(201, 168, 76, 0.08);
    border: 1px solid rgba(201, 168, 76, 0.25);
    color: var(--color-gold-light);
    border-radius: var(--radius-pill);
  }

  .blog-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    line-height: 1.25;
    font-weight: 500;
  }

  .blog-card__title a {
    color: var(--color-text);
    transition: color var(--t-base) var(--ease);
  }

  .blog-card__title a:hover {
    color: var(--color-gold-light);
  }

  .blog-card__excerpt {
    color: var(--color-muted);
    line-height: 1.65;
    flex: 1;
  }

  .blog-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--fs-sm);
    color: var(--color-muted);
  }

  .blog-card__author {
    color: var(--color-text);
    font-weight: 500;
  }

  .blog-card__dot {
    color: var(--color-gold);
  }

  .blog-card__link {
    align-self: flex-start;
    margin-top: var(--space-2);
  }
</style>
