---
import site from "@data/site.json";

const year = new Date().getFullYear();
const { brand, footer, contact } = site;
---

<footer class="footer">
  <div class="footer__top container">
    <div class="footer__col footer__brand">
      <a href="/" class="footer__logo">
        <span class="footer__logo-title">{brand.title}</span>
        <span class="footer__logo-tag">{brand.tag}</span>
      </a>
      <p class="footer__tagline">{brand.footerTagline}</p>
    </div>

    <div class="footer__col">
      <h4 class="footer__heading">{footer.quickLinksHeading}</h4>
      <ul class="footer__list">
        {footer.quickLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
      </ul>
    </div>

    <div class="footer__col">
      <h4 class="footer__heading">{footer.servicesHeading}</h4>
      <ul class="footer__list">
        {footer.serviceLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
      </ul>
    </div>

    <div class="footer__col">
      <h4 class="footer__heading">{footer.contactHeading}</h4>
      <address class="footer__address">
        <p>{contact.addressLine1}<br />{contact.addressLine2}<br />{contact.addressLine3}</p>
        <p>
          <a href={contact.phoneHref}>{contact.phone}</a><br />
          <a href={contact.emailHref}>{contact.email}</a>
        </p>
        <p class="footer__hours">{contact.hours}</p>
      </address>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>© {year} {footer.copyrightName} · <a href="/privacy/">Privacy Policy</a></p>
      <p class="footer__disclaimer">{footer.disclaimer}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-surface);
    border-top: 2px solid var(--color-gold);
    color: var(--color-text);
    margin-top: var(--space-9);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    padding-block: var(--space-9) var(--space-7);
  }

  @media (min-width: 640px) {
    .footer__top {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .footer__top {
      grid-template-columns: 1.4fr 1fr 1fr 1.2fr;
      gap: var(--space-6);
    }
  }

  .footer__brand {
    max-width: 360px;
  }

  .footer__logo {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: var(--space-4);
  }

  .footer__logo-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .footer__logo-tag {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .footer__tagline {
    color: var(--color-muted);
    font-size: var(--fs-sm);
    line-height: 1.7;
  }

  .footer__heading {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-5);
  }

  .footer__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__list a {
    color: var(--color-text);
    font-size: var(--fs-sm);
    transition: color var(--t-base) var(--ease);
  }

  .footer__list a:hover {
    color: var(--color-gold-light);
  }

  .footer__address {
    font-style: normal;
    color: var(--color-muted);
    font-size: var(--fs-sm);
    line-height: 1.8;
  }

  .footer__address p + p {
    margin-top: var(--space-3);
  }

  .footer__address a {
    color: var(--color-text);
    transition: color var(--t-base) var(--ease);
  }

  .footer__address a:hover {
    color: var(--color-gold-light);
  }

  .footer__hours {
    font-size: var(--fs-xs);
    color: var(--color-muted);
  }

  .footer__bottom {
    border-top: 1px solid var(--color-border);
  }

  .footer__bottom-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-block: var(--space-5);
    color: var(--color-muted);
    font-size: var(--fs-xs);
  }

  @media (min-width: 720px) {
    .footer__bottom-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .footer__bottom-inner a {
    color: var(--color-text);
    transition: color var(--t-base) var(--ease);
  }

  .footer__bottom-inner a:hover {
    color: var(--color-gold-light);
  }

  .footer__disclaimer {
    max-width: 540px;
  }
</style>
