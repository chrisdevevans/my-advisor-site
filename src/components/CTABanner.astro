---
export interface Props {
  eyebrow?: string;
  heading?: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  eyebrow,
  heading = "Ready to take control of your financial future?",
  description = "A conversation costs nothing. Clarity is the first step toward confidence.",
  ctaLabel = "Book a Free Call",
  ctaHref = "/contact/",
} = Astro.props;
---

<section class="cta-banner" aria-labelledby="cta-heading">
  <div class="cta-banner__pattern" aria-hidden="true">
    <svg viewBox="0 0 1200 280" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
      <g stroke="rgba(201,168,76,0.18)" stroke-width="1" fill="none">
        <line x1="0" y1="200" x2="1200" y2="60" />
        <line x1="0" y1="280" x2="1200" y2="120" />
        <line x1="600" y1="0" x2="1200" y2="280" />
      </g>
    </svg>
  </div>

  <div class="container cta-banner__inner fade-up">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h2 id="cta-heading" class="cta-banner__heading">{heading}</h2>
    {description && <p class="cta-banner__desc">{description}</p>}
    <a href={ctaHref} class="btn btn--primary cta-banner__btn">{ctaLabel}</a>
  </div>
</section>

<style>
  .cta-banner {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(135deg, rgba(201, 168, 76, 0.12) 0%, rgba(26, 58, 92, 0.18) 100%),
      var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .cta-banner__pattern {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.7;
  }

  .cta-banner__pattern svg {
    width: 100%;
    height: 100%;
  }

  .cta-banner__inner {
    position: relative;
    padding-block: var(--space-9);
    text-align: center;
    max-width: 720px;
    margin-inline: auto;
  }

  .cta-banner__heading {
    font-family: var(--font-display);
    font-weight: 500;
    margin-bottom: var(--space-4);
  }

  .cta-banner__desc {
    color: var(--color-muted);
    font-size: var(--fs-md);
    margin-bottom: var(--space-7);
  }

  .cta-banner__btn {
    min-width: 200px;
  }
</style>
