---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Heading from "@core-elements/heading/Heading.astro";
import Image from "@core-elements/image/Image.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import Text from "@core-elements/text/Text.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";
import Split from "@wrappers/split/Split.astro";

const {
  eyebrow = "",
  heading = "",
  subtext = "",
  imageSource = "",
  imageAlt = "",
  imageAspectRatio = "none",
  buttonSections = [],
  reverse = false,
  sectionLabel,
  maxContentWidth = "xl",
  paddingHorizontal = "lg",
  paddingVertical = "4xl",
  colorScheme = "inherit",
  backgroundColor,
  background,
  class: className,
  useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;
---

<CustomSection
  label={sectionLabel}
  maxContentWidth={maxContentWidth}
  paddingHorizontal={paddingHorizontal}
  paddingVertical={paddingVertical}
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  background={background}
  class:list={["hero", className]}
  useDefaultEditableBinding={useDefaultEditableBinding}
  {...htmlAttributes}
>
  <Split
    distributionMode="flexible-fixed"
    fixedWidth="400"
    alignmentVertical="center"
    reverse={reverse}
    minSplitWidth={800}
    gap="2xl"
    class="hero-split"
  >
    <Fragment slot="first">
      <SimpleText
        class="eyebrow"
        data-prop="eyebrow"
        text={eyebrow}
      />
      <Heading
        level="h1"
        size="2xl"
        data-prop="heading"
        >{heading}</Heading
      >
      <Text
        class="subtext"
        data-prop="subtext"
        text={subtext}
      />
      <ButtonGroup
        class="buttons-container"
        buttonSections={buttonSections}
        data-children-prop="buttonSections"
      />
    </Fragment>
    <Fragment slot="second">
      <Image
        source={imageSource}
        alt={imageAlt}
        rounded={true}
        aspectRatio={imageAspectRatio}
        data-prop-src="imageSource"
        data-prop-alt="imageAlt"
        priority={true}
      />
    </Fragment>
  </Split>
</CustomSection>
