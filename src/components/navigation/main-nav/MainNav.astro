---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Bar from "@components/navigation/bar/Bar.astro";
import Mobile from "@components/navigation/mobile/Mobile.astro";
import ThemeToggle from "@components/navigation/theme-toggle/ThemeToggle.astro";
import Image from "@core-elements/image/Image.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";

type NavButton = {
  text?: string;
  /** Button schema uses `link`; legacy entries may use `href`. */
  link?: string;
  href?: string;
  [key: string]: unknown;
};

const {
  logoSource,
  logoAlternateSource,
  logoAlt = "logo",
  navData = [],
  buttonSections = [] as NavButton[],
  themeToggle = false,
  class: className,
  useDefaultEditableBinding: _useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;

const mobileNavData = [
  ...navData,
  ...buttonSections.map((button: NavButton) => ({
    name: button.text || "Button",
    path: button.link || button.href || "#",
    children: [],
  })),
];
---

<CustomSection
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical="none"
  class:list={["main-nav", className]}
  {...htmlAttributes}
  useDefaultEditableBinding={false}
>
  <a
    href="/"
    class="main-nav-logo-link"
  >
    <Image
      source={logoSource}
      alternateSource={logoAlternateSource}
      class="main-nav-logo"
      alt={logoAlt}
      useDefaultEditableBinding={false}
    />
  </a>
  <div class="nav-end">
    <Bar
      navData={navData}
      class="desktop-main-nav"
    />

    {themeToggle && <ThemeToggle />}
    <ButtonGroup
      direction="row"
      align="center"
      class="desktop-button-group"
      buttonSections={buttonSections}
      useDefaultEditableBinding={false}
    />
  </div>
  <Mobile
    logoSource={logoSource}
    logoAlternateSource={logoAlternateSource}
    logoAlt={logoAlt}
    navData={mobileNavData}
    class="mobile-main-nav"
    useDefaultEditableBinding={false}
  />
</CustomSection>

<style is:global>
  @layer page-sections {
    .main-nav {
      background-color: var(--color-bg);
      padding-block: 0;
      position: sticky;
      top: 0;
      z-index: var(--layer-2);

      .desktop-main-nav,
      .desktop-button-group.button-group {
        @container (max-width: 768px) {
          display: none;
        }
      }

      .nav-hamburger.mobile-button {
        @container (min-width: 769px) {
          display: none;
        }
      }

      > .outer-content > .content {
        align-items: center;
        container-type: inline-size;
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-md);
        height: 5rem;

        > .main-nav-logo-link {
          align-items: center;
          display: flex;
          flex: 0 1 min(11rem, 100%);
          min-width: 0;
          width: min(11rem, 100%);
        }

        > .main-nav-logo-link > .main-nav-logo {
          display: flex;
          margin-top: 0 !important;
          max-width: none;
          width: 100%;
        }

        > .main-nav-logo-link > .main-nav-logo > .image-inner {
          width: 100%;
        }

        > .main-nav-logo-link > .main-nav-logo picture {
          display: block;
          width: 100%;
        }

        > .main-nav-logo-link > .main-nav-logo img,
        > .main-nav-logo-link > .main-nav-logo svg {
          display: block;
          height: 2rem;
          max-width: 100%;
          width: auto;
        }

        .button-group {
          margin-top: 0;
        }
      }

      > .outer-content > .content > .nav-end {
        align-items: center;
        display: flex;
        flex-shrink: 0;
        gap: var(--spacing-md);
        justify-content: flex-end;
        margin-left: auto;

        > .button-group {
          container-type: normal;
        }
      }
    }
  }
</style>
